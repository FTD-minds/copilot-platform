# Provider keys (set the ones you use; router is model-agnostic)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# AWS_BEDROCK_REGION=
# GOOGLE_VERTEX_PROJECT=

# Active provider/model (overridable per request)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet

# Database
DATABASE_URL=postgresql://copilot:copilot@localhost:5432/copilot

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# App
APP_ENV=development
LOG_LEVEL=INFO
